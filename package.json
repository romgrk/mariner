{
  "name": "mariner",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Mariner — a GNOME Files clone built with node-gtk + TypeScript",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romgrk/mariner.git"
  },
  "engines": {
    "node": ">=22.18"
  },
  "main": "src/main.ts",
  "bundle": {
    "name": "Mariner",
    "id": "io.github.romgrk.Mariner",
    "summary": "Browse and manage your files",
    "gtk": 4,
    "flatpak": {
      "runtimeVersion": "50",
      "finishArgs": ["--filesystem=host"],
      "lintExceptions": {
        "finish-args-host-filesystem-access": "Mariner is a file manager; browsing and managing the whole filesystem is its core function, same as other file managers on Flathub."
      }
    }
  },
  "bin": {
    "mariner": "bin/mariner"
  },
  "files": [
    "bin",
    "src",
    "data"
  ],
  "scripts": {
    "start": "node --import node-gtk/register src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-gtk": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
